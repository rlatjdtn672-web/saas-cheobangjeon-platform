# ───────────────────────────────────────────────────────────────
#  실전 SaaS 처방전 플랫폼 - 환경변수
#  이 파일을 복사해서 .env.local 로 만들고 값을 채우세요.
#  (키가 하나도 없어도 로컬에서는 메모리 모드로 동작합니다)
# ───────────────────────────────────────────────────────────────

# Supabase (DB + 트래픽 지표 영구 저장)
# Supabase 프로젝트 > Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 전용 키 (이벤트 기록용, 절대 클라이언트에 노출 금지)
# Supabase > Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# 사이트 공개 URL (배포 후 Vercel 도메인). 로컬은 비워두면 됩니다.
NEXT_PUBLIC_SITE_URL=
